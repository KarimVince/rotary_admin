DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/rotary_admin
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@rotaryadmin.app
RESEND_FROM_NAME=Rotary Club of Discovery Bay

ADMIN_EMAIL=admin@rotaryadmin.app
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=Admin

# Shared temporary password assigned to users auto-created from active
# members by `python -m app.db.seed` (Story 8.17). Members should change it
# after their first login.
MEMBER_SEED_PASSWORD=change-me

# Comma-separated list of origins allowed to call the API via CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Origin the frontend is reachable at — used to build password-reset links
# sent by email. Must be the real production frontend URL in production.
FRONTEND_BASE_URL=http://localhost:5173

# Where email attachments and generated application PDFs are stored on disk
# (short-lived — built, emailed, done — never needs to survive a restart)
UPLOAD_DIR=uploads
# Absolute origin the backend is reachable at — must be a real public URL in
# production, since Resend fetches email attachments from this address itself
PUBLIC_BASE_URL=http://localhost:8000
MAX_EMAIL_ATTACHMENT_BYTES=10485760

# Story 16.6 — Supabase Storage credentials for member photos, NGO logos, and
# PPT templates (Render's free tier wipes local disk on every restart, so
# these three upload types can't live in UPLOAD_DIR). Create a Supabase
# project, then Storage -> New bucket: "public-assets" (public) and
# "ppt-templates" (private). SUPABASE_SERVICE_ROLE_KEY is the project's
# service_role key (Settings -> API) — never the anon key, and never expose
# it to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
