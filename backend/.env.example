DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/rotary_admin
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@rotaryadmin.app
RESEND_FROM_NAME=Rotary Club of Discovery Bay

ADMIN_EMAIL=admin@rotaryadmin.app
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=Admin

# Shared temporary password assigned to users auto-created from active
# members by `python -m app.db.seed` (Story 8.17). Members should change it
# after their first login.
MEMBER_SEED_PASSWORD=change-me

# Comma-separated list of origins allowed to call the API via CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Where uploaded files (member photos, email attachments) are stored on disk
UPLOAD_DIR=uploads
# Absolute origin the backend is reachable at — must be a real public URL in
# production, since Resend fetches email attachments from this address itself
PUBLIC_BASE_URL=http://localhost:8000
MAX_EMAIL_ATTACHMENT_BYTES=10485760
